#include <Arduino.h>
#include <Wire.h>

#define STEP_PIN 18
#define DIR_PIN  19

#define AS5600_ADDR 0x36

float stepsPerDeg = 1600.0 / 360.0;

int angles[] = {70, 200, 140, 280, 10};

float zeroOffset = 0;

// 🔹 Read raw angle
uint16_t readRawAngle() {
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x0C);
  Wire.endTransmission();

  Wire.requestFrom(AS5600_ADDR, 2);

  uint16_t high = Wire.read();
  uint16_t low  = Wire.read();

  return (high << 8) | low;
}

// 🔹 Convert to degrees + zero correction
float getAngle() {
  uint16_t raw = readRawAngle();

  float angle = (raw / 4096.0) * 360.0;

  angle = angle - zeroOffset;

  if (angle < 0) angle += 360;

  return angle;
}

// 🔹 Step motor + read during motion
void stepMotor(int steps, bool dir) {
  digitalWrite(DIR_PIN, dir);

  unsigned long lastReadTime = 0;

  for (int i = 0; i < steps; i++) {

    // step pulse
    digitalWrite(STEP_PIN, HIGH);
    delayMicroseconds(1500);
    digitalWrite(STEP_PIN, LOW);
    delayMicroseconds(1500);

    // read every 800 ms
    if (millis() - lastReadTime >= 200) {
      float angle = getAngle();
      Serial.print("Angle: ");
      Serial.println(angle);

      lastReadTime = millis();
    }
  }
  float angle = getAngle();
  Serial.print("Final Angle: ");
  Serial.println(angle);
}

void setup() {
  Serial.begin(115200);

  Wire.begin(21, 22);

  pinMode(STEP_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);

  // set zero position
  delay(2000);
  zeroOffset = (readRawAngle() / 4096.0) * 360.0;
}

void loop() {
  int currentAngle = 0;

  for (int i = 0; i < 5; i++) {
    int target = angles[i];

    int diff = target - currentAngle;

    bool dir = (diff < 0);  // fixed direction

    int steps = abs(diff) * stepsPerDeg;

    stepMotor(steps, dir);

    currentAngle = target;

    delay(2000); // pause between moves
  }

  while (1); // stop after one run
}




